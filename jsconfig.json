{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "*": ["creature-sim/src/*"]
    }
  },
  "include": ["creature-sim/src/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
